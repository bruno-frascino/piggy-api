# Database
DATABASE_URL="postgresql://username:password@localhost:5432/piggy_db"

# Server Configuration
PORT=4000
NODE_ENV=development
# Auto-apply pending Prisma migrations on server startup (development only)
DB_AUTO_MIGRATE=true

# CORS Configuration
CORS_ORIGIN="http://localhost:3000"

# JWT Authentication
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_REFRESH_SECRET="change-this-to-a-different-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Symbol search is powered by Yahoo Finance public search endpoint (no API key required)
